@model IEnumerable<BordGameSpace.Models.SpaceReservation>
@{
    ViewData["Title"] = "我的訂位預約";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-body text-center">
                <h4>@ViewBag.MemberName</h4>
                <span class="badge bg-primary">@ViewBag.MemberLevel</span>
            </div>
        </div>
        <partial name="_MemberNav" />
    </div>

    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3>📅 我的訂位預約</h3>
            <a asp-action="Create" class="btn btn-primary">+ 新增預約</a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }

        @if (!Model.Any())
        {
            <div class="alert alert-info">尚無訂位預約記錄</div>
        }
        else
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>預約日期</th>
                        <th>時段</th>
                        <th>人數</th>
                        <th>空間</th>
                        <th>狀態</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>@r.ReservationDate.ToString("yyyy-MM-dd")</td>
                            <td>@r.StartTime - @r.EndTime</td>
                            <td>@r.PeopleCount 人</td>
                            <td>@r.SpaceType</td>
                            <td>
                                @if (r.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark">審核中</span>
                                }
                                else if (r.Status == "Approved")
                                {
                                    <span class="badge bg-success">已通過</span>
                                }
                                else if (r.Status == "Rejected")
                                {
                                    <span class="badge bg-danger">已拒絕</span>
                                }
                                else if (r.Status == "Cancelled")
                                {
                                    <span class="badge bg-secondary">已取消</span>
                                }
                            </td>
                            <td>
                                @if (r.Status == "Pending")
                                {
                                    <a asp-action="Cancel" asp-route-id="@r.Id" class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('確定取消預約？')">取消</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>