@model BordGameSpace.DTOs.LoginDto
@{
    ViewData["Title"] = "會員登入";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="text-center mb-4">會員登入</h2>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                }

                <form asp-action="Login" method="post">
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                    <div class="mb-3">
                        <label asp-for="Account" class="form-label">電話 / Email</label>
                        <input asp-for="Account" class="form-control" placeholder="請輸入電話或Email" />
                        <span asp-validation-for="Account" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">密碼</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="請輸入密碼" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="RememberMe" type="checkbox" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">記住我</label>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">登入</button>
                    </div>
                </form>

                <p class="text-center mt-3">
                    <a asp-controller="Admin" asp-action="Login" class="text-muted small">後台登入</a>
                </p>

                <hr class="my-4" />

                <p class="text-center">
                    還沒有帳號？<a asp-action="Register">立即註冊</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
