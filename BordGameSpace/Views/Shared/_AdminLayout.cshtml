<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 菠德後台管理</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-controller="Admin" asp-action="Index">🎲 菠德後台</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Index">📊 儀表板</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Pos" asp-action="Index">🛒 POS</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="PlayRecords" asp-action="Index">🎮 遊玩紀錄</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="GameRentals" asp-action="AdminIndex">🎲 遊戲租借</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="SpaceReservations" asp-action="AdminIndex">📅 訂位預約</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Orders" asp-action="Index">🧾 訂單管理</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Products" asp-action="Index">🛒 商品管理</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Restock" asp-action="Index">📦 進貨紀錄</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Members" asp-action="Index">👥 會員管理</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Levels" asp-action="Index">🏅 等級管理</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Coupons" asp-action="Index">🎟️ 優惠券</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Events" asp-action="Index">🎪 活動</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Reports" asp-action="Index">📊 報表</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Logout">🚪 登出</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }

        @RenderBody()
    </div>

    <footer class="mt-5 py-3 bg-light text-center">
        <div class="container">
            <span class="text-muted">&copy; 2026 - 菠德桌上遊戲空間 管理系統</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
