@model BordGameSpace.Models.Level
@{
    ViewData["Title"] = "新增等級";
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">新增等級</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">等級名稱 *</label>
                        <input asp-for="Name" class="form-control" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="UpgradeThresholdHours" class="form-label">升級時數門檻（小時）</label>
                                <input asp-for="UpgradeThresholdHours" type="number" step="0.01" class="form-control" value="0" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="UpgradeThresholdAmount" class="form-label">升級金額門檻（元）</label>
                                <input asp-for="UpgradeThresholdAmount" type="number" step="1" class="form-control" value="0" />
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="GameDiscount" class="form-label">遊戲購買折扣（0.9=9折, 1.0=原價）</label>
                        <input asp-for="GameDiscount" type="number" step="0.01" class="form-control" value="1.0" />
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="WeekdayHourlyRate" class="form-label">平日場地費（元/小時）</label>
                                <input asp-for="WeekdayHourlyRate" type="number" class="form-control" value="0" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="HolidayHourlyRate" class="form-label">假日場地費（元/小時）</label>
                                <input asp-for="HolidayHourlyRate" type="number" class="form-control" value="0" />
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">儲存</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">取消</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
