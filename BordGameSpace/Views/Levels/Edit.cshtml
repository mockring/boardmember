@model BordGameSpace.Models.Level
@{
    ViewData["Title"] = "編輯等級";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>✏️ 編輯等級</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">返回列表</a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<form method="post" asp-action="Edit">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id">
    <input type="hidden" asp-for="CreatedAt">

    <div class="row g-3">
        <!-- 基本設定 -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">📋 基本設定</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">等級名稱 *</label>
                        <input asp-for="Name" class="form-control" required maxlength="50">
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">排序（數字越小越前面）</label>
                        <input asp-for="SortOrder" type="number" class="form-control">
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="IsDefault" class="form-check-input" id="isDefault">
                            <label class="form-check-label" for="isDefault">預設等級</label>
                        </div>
                        <div class="form-text">新會員註冊時預設套用此等級</div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="IsDeletable" class="form-check-input" id="isDeletable">
                            <label class="form-check-label" for="isDeletable">可刪除</label>
                        </div>
                        <div class="form-text">取消勾選後此等級不可被刪除</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 升級門檻 -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header"><h5 class="mb-0">📈 升級門檻</h5></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">累積遊玩時數門檻（小時）</label>
                        <input asp-for="UpgradeThresholdHours" type="number" step="0.01" min="0" class="form-control">
                        <div class="form-text">會員需同時滿足時數與金額門檻才會升級</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">累積消費金額門檻（元）</label>
                        <input asp-for="UpgradeThresholdAmount" type="number" step="1" min="0" class="form-control">
                    </div>
                </div>
            </div>
        </div>

        <!-- 福利設定 -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header"><h5 class="mb-0">🎁 福利設定</h5></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">遊戲購買折扣</label>
                        <div class="input-group">
                            <input asp-for="GameDiscount" type="number" step="0.01" min="0" max="1" class="form-control">
                            <span class="input-group-text">（0.95 = 95折）</span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <div class="mb-3">
                                <label class="form-label">平日場地費</label>
                                <div class="input-group">
                                    <input asp-for="WeekdayHourlyRate" type="number" min="0" class="form-control">
                                    <span class="input-group-text">元/小時</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="mb-3">
                                <label class="form-label">假日場地費</label>
                                <div class="input-group">
                                    <input asp-for="HolidayHourlyRate" type="number" min="0" class="form-control">
                                    <span class="input-group-text">元/小時</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">儲存修改</button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">取消</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
