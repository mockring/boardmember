@model BordGameSpace.Models.Member
@{
    ViewData["Title"] = "會員專區";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-body text-center">
                <h4>@Model.Name</h4>
                <span class="badge bg-primary">@Model.Level?.Name</span>
            </div>
        </div>
        <div class="list-group">
            <a asp-action="Index" class="list-group-item list-group-item-action active">會員專區</a>
            <a asp-action="Profile" class="list-group-item list-group-item-action">我的資料</a>
            <a asp-action="Orders" class="list-group-item list-group-item-action">我的訂單</a>
        </div>
    </div>

    <div class="col-md-9">
        <h3>歡迎，@Model.Name！</h3>
        <p class="text-muted">會員等級：<strong>@Model.Level?.Name</strong></p>

        <div class="row mt-4">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body text-center">
                        <h2>@Model.TotalPlayHours</h2>
                        <p class="text-muted mb-0">累積遊玩時數</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body text-center">
                        <h2>@Model.TotalSpending.ToString("C0")</h2>
                        <p class="text-muted mb-0">累積消費</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body text-center">
                        <h2>-</h2>
                        <p class="text-muted mb-0">我的積分</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <h5>會員福利</h5>
            <ul class="list-group">
                <li class="list-group-item">
                    遊戲購買折扣：@((Model.Level?.GameDiscount * 10 ?? 10).ToString("0.0")) 折
                </li>
                <li class="list-group-item">
                    平日場地費：@Model.Level?.WeekdayHourlyRate 元/小時
                </li>
                <li class="list-group-item">
                    假日場地費：@Model.Level?.HolidayHourlyRate 元/小時
                </li>
            </ul>
        </div>
    </div>
</div>
