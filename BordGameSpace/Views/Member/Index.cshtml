@model BordGameSpace.Models.Member
@{
    ViewData["Title"] = "會員專區";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-body text-center">
                <h4>@Model.Name</h4>
                <span class="badge bg-primary">@Model.Level?.Name</span>
            </div>
        </div>
        <partial name="_MemberNav" />
    </div>

    <div class="col-md-9">
        <h3>歡迎，@Model.Name！</h3>
        <p class="text-muted">會員等級：<strong>@Model.Level?.Name</strong></p>

        <div class="row mt-4">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body text-center">
                        <h2>@Model.TotalPlayHours</h2>
                        <p class="text-muted mb-0">累積遊玩時數</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body text-center">
                        <h2>@Model.TotalSpending.ToString("C0")</h2>
                        <p class="text-muted mb-0">累積消費</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>