@model BordGameSpace.Models.Member
@{
    ViewData["Title"] = "編輯資料";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-body text-center">
                <h4>@Model.Name</h4>
                <span class="badge bg-primary">@Model.Level?.Name</span>
            </div>
        </div>
        <div class="list-group">
            <a asp-action="Profile" class="list-group-item list-group-item-action">我的資料</a>
            <a asp-action="Orders" class="list-group-item list-group-item-action">我的訂單</a>
            <a asp-action="ChangePassword" class="list-group-item list-group-item-action">修改密碼</a>
        </div>
    </div>

    <div class="col-md-9">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">編輯會員資料</h5>
            </div>
            <div class="card-body">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }

                <form asp-action="Edit" method="post">
                    <div class="mb-3">
                        <label class="form-label">姓名</label>
                        <input type="text" name="name" class="form-control" value="@Model.Name" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">電話</label>
                        <input type="text" name="phone" class="form-control" value="@Model.Phone" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" value="@Model.Email" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">生日</label>
                        <input type="date" name="birthday" class="form-control"
                               value="@(Model.Birthday?.ToString("yyyy-MM-dd") ?? "")" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">儲存</button>
                        <a asp-action="Profile" class="btn btn-outline-secondary">取消</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
