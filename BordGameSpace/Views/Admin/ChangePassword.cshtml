@{
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>🔑 修改密碼</h3>
</div>

<div class="card">
    <div class="card-body">
        @if (ViewData["Success"] != null && (bool)ViewData["Success"]!)
        {
            <div class="alert alert-success mb-4">✅ 密碼修改成功！</div>
        }

        <form method="post" asp-action="ChangePassword" asp-controller="Admin">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">目前密碼</label>
                <input type="password" name="CurrentPassword" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">新密碼</label>
                <input type="password" name="NewPassword" class="form-control" required minlength="6" />
                <small class="text-muted">至少 6 個字元</small>
            </div>

            <div class="mb-4">
                <label class="form-label">確認新密碼</label>
                <input type="password" name="ConfirmPassword" class="form-control" required />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">儲存</button>
                <a href="/Admin" class="btn btn-outline-secondary">返回</a>
            </div>
        </form>
    </div>
</div>
