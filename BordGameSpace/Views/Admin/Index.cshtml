@{
    ViewData["Title"] = "後台管理";
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col-md-12">
        <h2 class="mb-4">📊 後台儀表板</h2>
    </div>
</div>

<!-- 快速功能按鈕 -->
<div class="row mb-4">
    <div class="col-md-6">
        <a asp-controller="Pos" asp-action="Index" class="btn btn-primary btn-lg w-100 py-3">
            <i class="bi bi-cart-fill"></i> 🚀 快速消費 POS
        </a>
    </div>
</div>


<!-- 進行中的遊玩明細 -->
<div class="row mt-4">
    <div class="col-md-12">
        <div class="card border-info">
            <div class="card-header bg-info text-white">
                <a asp-controller="PlayRecords" asp-action="AdminIndex" class="text-decoration-none text-white">🎮 進行中的遊玩 (@(ViewBag.ActivePlayCount ?? 0) 人)</a>
            </div>
            <div class="card-body">
                @{
                    var plays = ViewBag.ActivePlays as List<BordGameSpace.Models.PlayRecord>;
                    var hasUnpaid = plays?.Any(p => p.Status == "Completed") ?? false;
                }
                @if (plays != null && plays.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>姓名</th>
                                <th>電話</th>
                                <th>開始時間</th>
                                <th>已玩時數</th>
                                <th>狀態</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var play in plays)
                            {
                                <tr class="@(play.Status == "Completed" ? "table-warning" : "")">
                                    <td>@play.MemberName</td>
                                    <td>@play.MemberPhone</td>
                                    <td>@play.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        @{
                                            var endTime = play.EndTime ?? (DateTime)ViewBag.TaiwanNow;
                                            var elapsed = endTime - play.StartTime;
                                            var hours = Math.Floor(elapsed.TotalHours);
                                            var mins = elapsed.Minutes;
                                            <text>@hours 小時 @mins 分</text>
                                        }
                                    </td>
                                    <td>
                                        @if (play.Status == "Playing")
                                        {
                                            <span class="badge bg-success">遊玩中</span>
                                        }
                                        else if (play.Status == "Completed")
                                        {
                                            <span class="badge bg-warning text-dark">待結帳</span>
                                        }
                                    </td>
                                    <td>
                                        @if (play.Status == "Playing")
                                        {
                                            <a asp-controller="PlayRecords" asp-action="EndPlay" asp-route-id="@play.Id" class="btn btn-sm btn-outline-primary">結束遊玩</a>
                                        }
                                        else if (play.Status == "Completed")
                                        {
                                            <a asp-controller="Pos" asp-action="CheckoutPlay" asp-route-playId="@play.Id" class="btn btn-sm btn-warning">結帳</a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-center text-muted mb-0">目前沒有進行中的遊玩</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- 進行中的遊戲租借明細 -->
<div class="row mt-4">
    <div class="col-md-12">
        <div class="card border-warning">
            <div class="card-header bg-warning text-dark">
                <a asp-controller="GameRentals" asp-action="AdminIndex" class="text-decoration-none text-dark">🎲 遊戲租借 (@(ViewBag.ActiveRentalCount ?? 0) 筆)</a>
            </div>
            <div class="card-body">
                @{
                    var rentals = ViewBag.ActiveRentals as List<BordGameSpace.Models.GameRental>;
                }
                @if (rentals != null && rentals.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>租借日期</th>
                                <th>遊戲名稱</th>
                                <th>租借人</th>
                                <th>電話</th>
                                <th>取件日期</th>
                                <th>狀態</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rental in rentals)
                            {
                                <tr>
                                    <td>@rental.CreatedAt.ToString("yyyy-MM-dd")</td>
                                    <td>@rental.Product?.Name</td>
                                    <td>@(rental.Member?.Name ?? rental.RenterName)</td>
                                    <td>@(rental.Member?.Phone ?? rental.RenterPhone)</td>
                                    <td>@(rental.PickupDate?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                    <td>
                                        @if (rental.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark">審核中</span>
                                        }
                                        else if (rental.Status == "Approved")
                                        {
                                            <span class="badge bg-primary">已通過</span>
                                        }
                                        else if (rental.Status == "Borrowed")
                                        {
                                            <span class="badge bg-info">已借出</span>
                                        }
                                    </td>
                                    <td>
                                        @if (rental.Status == "Pending")
                                        {
                                            <a asp-controller="GameRentals" asp-action="Approve" asp-route-id="@rental.Id" class="btn btn-sm btn-success" onclick="return confirm('確定通過申請？')">通過</a>
                                            <a asp-controller="GameRentals" asp-action="Reject" asp-route-id="@rental.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('確定取消申請？')">取消</a>
                                        }
                                        else if (rental.Status == "Approved")
                                        {
                                            <a asp-controller="GameRentals" asp-action="Borrow" asp-route-id="@rental.Id" class="btn btn-sm btn-primary" onclick="return confirm('確定已取貨借出？')">借出</a>
                                        }
                                        else if (rental.Status == "Borrowed")
                                        {
                                            <a asp-controller="GameRentals" asp-action="Return" asp-route-id="@rental.Id" class="btn btn-sm btn-outline-success" onclick="return confirm('確定已完成歸還？')">歸還</a>
                                            @if (rental.OrderId == null)
                                            {
                                                <a asp-controller="GameRentals" asp-action="CreateOrder" asp-route-id="@rental.Id" class="btn btn-sm btn-primary">建立訂單</a>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">已開單</span>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-center text-muted mb-0">目前沒有進行中的遊戲租借</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- 訂位預約明細 -->
<div class="row mt-4">
    <div class="col-md-12">
        <div class="card border-success">
            <div class="card-header bg-success text-white">
                <a asp-controller="SpaceReservations" asp-action="AdminIndex" class="text-decoration-none text-white">📅 訂位預約 (@(ViewBag.UpcomingReservationCount ?? 0) 筆)</a>
            </div>
            <div class="card-body">
                @{
                    var reservations = ViewBag.UpcomingReservations as List<BordGameSpace.Models.SpaceReservation>;
                }
                @if (reservations != null && reservations.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>預約日期</th>
                                <th>姓名</th>
                                <th>電話</th>
                                <th>時段</th>
                                <th>狀態</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in reservations)
                            {
                                <tr>
                                    <td>@r.ReservationDate.ToString("yyyy-MM-dd")</td>
                                    <td>@r.Name</td>
                                    <td>@r.Phone</td>
                                    <td>@r.StartTime - @r.EndTime</td>
                                    <td>
                                        @if (r.Status == "Approved")
                                        {
                                            <span class="badge bg-success">已通過</span>
                                        }
                                        else if (r.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark">審核中</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-center text-muted mb-0">目前沒有已預訂的訂位預約</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- 報名中的活動 -->
<div class="row mt-4">
    <div class="col-md-12">
        <div class="card border-secondary">
            <div class="card-header bg-secondary text-white">
                <a asp-controller="Events" asp-action="Index" class="text-decoration-none text-white">📋 報名中的活動 (@(ViewBag.OpenEventCount ?? 0) 筆)</a>
            </div>
            <div class="card-body">
                @{
                    var openEvents = ViewBag.OpenEvents as List<BordGameSpace.Models.Event>;
                }
                @if (openEvents != null && openEvents.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>活動名稱</th>
                                <th>日期</th>
                                <th>報名狀態</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var evt in openEvents)
                            {
                                <tr>
                                    <td><a asp-controller="Events" asp-action="Details" asp-route-id="@evt.Id">@evt.Title</a></td>
                                    <td>@evt.EventDate.ToString("yyyy-MM-dd")</td>
                                    <td>@evt.Registrations.Count@(evt.MaxParticipants.HasValue ? "/" + evt.MaxParticipants.Value : "") 人</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-center text-muted mb-0">目前沒有報名中的活動</p>
                }
            </div>
        </div>
    </div>
</div>

