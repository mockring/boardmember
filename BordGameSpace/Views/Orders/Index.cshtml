@model IEnumerable<BordGameSpace.Models.Order>
@{
    ViewData["Title"] = "訂單管理";
    Layout = "_AdminLayout";

    var orderTypes = new[] { "All", "Product", "Play", "Space", "GameRental" };
    var orderTypeLabels = new Dictionary<string, string>
    {
        { "All", "全部類型" },
        { "Product", "商品購買" },
        { "Play", "現場遊玩" },
        { "Space", "空間租借" },
        { "GameRental", "遊戲租借" }
    };
    var statusLabels = new Dictionary<string, string>
    {
        { "All", "全部狀態" },
        { "Paid", "已付款" },
        { "Unpaid", "未付款" }
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>🧾 訂單管理</h3>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* 篩選表單 *@
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-2">
                <label class="form-label">開始日期</label>
                <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate" />
            </div>
            <div class="col-md-2">
                <label class="form-label">結束日期</label>
                <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate" />
            </div>
            <div class="col-md-2">
                <label class="form-label">會員/電話搜尋</label>
                <input type="text" name="search" class="form-control" placeholder="姓名或電話" value="@ViewBag.Search" />
            </div>
            <div class="col-md-2">
                <label class="form-label">訂單類型</label>
                <select name="orderType" class="form-select">
                    @foreach (var t in orderTypes)
                    {
                        <option value="@t" selected="@(ViewBag.OrderType == t)">@orderTypeLabels[t]</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">付款狀態</label>
                <select name="paymentStatus" class="form-select">
                    <option value="All" selected="@(ViewBag.PaymentStatus == null || ViewBag.PaymentStatus == "All")">全部狀態</option>
                    <option value="Paid" selected="@(ViewBag.PaymentStatus == "Paid")">已付款</option>
                    <option value="Unpaid" selected="@(ViewBag.PaymentStatus == "Unpaid")">未付款</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary">篩選</button>
                <a asp-action="Index" class="btn btn-outline-secondary">清除</a>
            </div>
        </form>
    </div>
</div>

@* 訂單列表 *@
<div class="card">
    <div class="card-body">
        @if (!Model.Any())
        {
            <p class="text-muted text-center my-4">尚無訂單紀錄</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>日期</th>
                            <th>會員</th>
                            <th>電話</th>
                            <th>類型</th>
                            <th>原價</th>
                            <th>折扣</th>
                            <th>實收</th>
                            <th>付款方式</th>
                            <th>狀態</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td><strong>@order.Id</strong></td>
                                <td>@order.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    @if (order.Member != null)
                                    {
                                        <span>@order.Member.Name</span>
                                        <br /><small class="text-muted">@order.Member.Level?.Name</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">@order.MemberName</span>
                                    }
                                </td>
                                <td>@(order.MemberPhone ?? "-")</td>
                                <td>
                                    @{
                                        var typeLabel = orderTypes.Contains(order.OrderType) ? orderTypeLabels.GetValueOrDefault(order.OrderType, order.OrderType) : order.OrderType;
                                    }
                                    <span class="badge bg-info">@typeLabel</span>
                                </td>
                                <td class="text-end">@order.TotalAmount.ToString("C0")</td>
                                <td class="text-end text-danger">@order.DiscountAmount.ToString("C0")</td>
                                <td class="text-end fw-bold">@order.FinalAmount.ToString("C0")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(order.PaymentMethod))
                                    {
                                        <span class="badge bg-secondary">@order.PaymentMethod</span>
                                    }
                                </td>
                                <td>
                                    @if (order.PaymentStatus == "Paid")
                                    {
                                        <span class="badge bg-success">已付款</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">未付款</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">詳情</a>
                                    @if (order.PaymentStatus != "Paid")
                                    {
                                        <a asp-action="Delete" asp-route-id="@order.Id" class="btn btn-sm btn-outline-danger"
                                           onclick="return confirm('確定要刪除此訂單嗎？')">刪除</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-secondary fw-bold">
                            <td colspan="5" class="text-end">本月合計：</td>
                            <td class="text-end">@Model.Sum(o => o.TotalAmount).ToString("C0")</td>
                            <td class="text-end text-danger">@Model.Sum(o => o.DiscountAmount).ToString("C0")</td>
                            <td class="text-end">@Model.Sum(o => o.FinalAmount).ToString("C0")</td>
                            <td colspan="3"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <p class="text-muted mt-2">共 @Model.Count() 筆訂單</p>
        }
    </div>
</div>
