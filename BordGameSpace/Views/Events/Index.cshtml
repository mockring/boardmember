@model IEnumerable<BordGameSpace.Models.Event>
@{
    ViewData["Title"] = "活動管理";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>🎪 活動管理</h3>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">+ 新增活動</a>
    </div>
</div>

<form method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-auto">
            <select name="status" class="form-select" onchange="this.form.submit()">
                <option value="">全部狀態</option>
                <option value="RegistrationOpen" selected='@(ViewBag.Status == "RegistrationOpen")'>報名中</option>
                <option value="RegistrationClosed" selected='@(ViewBag.Status == "RegistrationClosed")'>報名截止</option>
                <option value="Ended" selected='@(ViewBag.Status == "Ended")'>已結束</option>
            </select>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary">清除篩選</a>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>名稱</th>
                    <th>活動日期</th>
                    <th>報名截止</th>
                    <th>報名人數</th>
                    <th>狀態</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    var registrationCount = e.Registrations?.Count ?? 0;
                    <tr>
                        <td>@e.Title</td>
                        <td>@e.EventDate.ToString("yyyy/MM/dd HH:mm")</td>
                        <td>@e.RegistrationDeadline.ToString("yyyy/MM/dd HH:mm")</td>
                        <td>
                            @(e.MaxParticipants.HasValue ? $"{registrationCount} / {e.MaxParticipants}" : $"{registrationCount}（無上限）")
                        </td>
                        <td>
                            @switch (e.Status)
                            {
                                case "RegistrationOpen":
                                    <span class="badge bg-success">報名中</span>
                                    break;
                                case "RegistrationClosed":
                                    <span class="badge bg-warning text-dark">報名截止</span>
                                    break;
                                case "Ended":
                                    <span class="badge bg-secondary">已結束</span>
                                    break;
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@e.Id" class="btn btn-sm btn-outline-secondary">詳情</a>
                            <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-outline-secondary">編輯</a>
                            <form method="post" asp-action="Delete" asp-route-id="@e.Id" style="display:inline">
                                <button type="submit" class="btn btn-sm btn-outline-secondary"
                                        onclick="return confirm('確定要刪除嗎？')">刪除</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted">尚無活動</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>