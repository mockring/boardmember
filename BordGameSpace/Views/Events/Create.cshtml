@model BordGameSpace.Models.Event
@{
    ViewData["Title"] = "新增活動";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>➕ 新增活動</h3>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label class="form-label">活動名稱</label>
                <input asp-for="Title" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">活動內容</label>
                <textarea asp-for="Content" class="form-control" rows="5" required></textarea>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">活動日期</label>
                    <input asp-for="EventDate" type="datetime-local" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">報名截止日</label>
                    <input asp-for="RegistrationDeadline" type="datetime-local" class="form-control" required />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">人數上限（留空表示不限制）</label>
                <input asp-for="MaxParticipants" type="number" class="form-control" min="1" />
            </div>
            <div class="mb-3">
                <label class="form-label">狀態</label>
                <select asp-for="Status" class="form-select">
                    <option value="RegistrationOpen">報名中</option>
                    <option value="RegistrationClosed">報名截止</option>
                    <option value="Ended">已結束</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="ImageUrl" class="form-label">圖片網址</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                <small class="text-muted">直接貼上圖片連結即可</small>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">儲存</button>
                <a asp-action="Index" class="btn btn-outline-secondary">返回</a>
            </div>
        </form>
    </div>
</div>

