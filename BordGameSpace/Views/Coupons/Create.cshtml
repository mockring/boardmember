@model BordGameSpace.Models.Coupon
@{
    ViewData["Title"] = "新增優惠券";
    Layout = "_AdminLayout";
}

<h2>🎫 新增優惠券</h2>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">優惠券名稱 *</label>
                    <input asp-for="Name" class="form-control" placeholder="例如：週年慶滿千折百" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">優惠券類型 *</label>
                    <select asp-for="CouponType" class="form-select">
                        <option value="FixedAmount">折價（固定金額）</option>
                        <option value="Percentage">折扣（百分比）</option>
                    </select>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label">折扣值 *</label>
                    <input asp-for="DiscountValue" class="form-control" type="number" min="1" step="1" />
                    <small class="text-muted">折價：填金額（元）；折扣%：填數字（如 9.5 代表 9.5%）</small>
                </div>
                <div class="col-md-4">
                    <label class="form-label">最低消費</label>
                    <input asp-for="MinPurchase" class="form-control" type="number" min="0" step="1" value="0" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">適用範圍 *</label>
                    <select asp-for="ApplicableTo" class="form-select">
                        <option value="All">全部</option>
                        <option value="Product">僅商品</option>
                        <option value="Play">僅遊玩</option>
                        <option value="Space">僅空間</option>
                    </select>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label">開始日期 *</label>
                    <input asp-for="ValidFrom" class="form-control" type="date"
                           value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">截止日期</label>
                    <input asp-for="ValidUntil" class="form-control" type="date" />
                    <div class="form-check mt-1">
                        <input class="form-check-input" type="checkbox" id="noExpiryCheck" />
                        <label class="form-check-label" for="noExpiryCheck">不限時間</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">發行數量</label>
                    <input asp-for="TotalQuantity" class="form-control" type="number" min="0" placeholder="留空代表不限張數" />
                    <small class="text-muted">留空 = 不限張數，0 = 已用完</small>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">送出</button>
                <a asp-action="Index" class="btn btn-secondary">取消</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('noExpiryCheck').addEventListener('change', function() {
        document.getElementById('ValidUntil').disabled = this.checked;
        if (this.checked) document.getElementById('ValidUntil').value = '';
    });
</script>
}
