@model BordGameSpace.Models.Coupon
@{
    ViewData["Title"] = "發放優惠券";
    Layout = "_AdminLayout";
    var levels = ViewBag.Levels as List<BordGameSpace.Models.Level>;
}

<h2>🎫 發放優惠券 — @Model.Name</h2>

<div class="card mb-4">
    <div class="card-header bg-info text-white">
        優惠券資訊
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-3">
                <strong>類型：</strong>
                @(Model.CouponType == "FixedAmount" ? "折價" : "折扣%")
            </div>
            <div class="col-md-3">
                <strong>折扣值：</strong>
                @(Model.CouponType == "FixedAmount" ? $"{Model.DiscountValue:C0} 元" : $"{Model.DiscountValue}%")
            </div>
            <div class="col-md-3">
                <strong>有效期限：</strong>
                @Model.ValidFrom.ToString("yyyy/MM/dd") ~ @(Model.ValidUntil?.ToString("yyyy/MM/dd") ?? "不限")
            </div>
            <div class="col-md-3">
                <strong>發行數量：</strong> @(Model.TotalQuantity?.ToString() ?? "不限")
            </div>
        </div>
    </div>
</div>

<!-- 發放給指定會員 -->
<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        發放給指定會員
    </div>
    <div class="card-body">
        <form asp-action="Assign" method="post" class="row g-3">
            <input type="hidden" name="couponId" value="@Model.Id" />
            <div class="col-md-4">
                <label class="form-label">會員電話</label>
                <input name="phone" class="form-control" placeholder="輸入電話查詢" />
            </div>
            <div class="col-md-4">
                <label class="form-label">選擇會員（搜尋結果）</label>
                <select name="memberId" class="form-select" id="memberSelect" required>
                    <option value="">— 先搜尋電話 —</option>
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary">發放</button>
            </div>
        </form>
    </div>
</div>

<!-- 依等級發放 -->
@if (levels != null && levels.Count > 0)
{
    <div class="card">
        <div class="card-header bg-warning text-dark">
            依等級發放
        </div>
        <div class="card-body">
            <form asp-action="AssignByLevel" method="post">
                <input type="hidden" name="couponId" value="@Model.Id" />
                <div class="row g-2">
                    <div class="col-md-6">
                        <select name="levelId" class="form-select" required>
                            <option value="">— 選擇等級 —</option>
                            @foreach (var lvl in levels)
                            {
                                <option value="@lvl.Id">@lvl.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <button type="submit" class="btn btn-warning">發放</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">返回列表</a>
</div>

@section Scripts {
    <script>
        document.querySelector('input[name="phone"]').addEventListener('change', async function () {
            const phone = this.value.trim();
            if (!phone) return;

            const res = await fetch(`/Coupons/SearchMembers?phone=${encodeURIComponent(phone)}`);
            const members = await res.json();

            const select = document.getElementById('memberSelect');
            select.innerHTML = '<option value="">— 選擇會員 —</option>';

            if (members.length === 0) {
                alert('找不到該電話的會員');
                return;
            }

            members.forEach(m => {
                const opt = document.createElement('option');
                opt.value = m.id;
                opt.text = `${m.name} (${m.phone}) — ${m.levelName}`;
                select.appendChild(opt);
            });
        });
    </script>
}
