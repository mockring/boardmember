@{
    ViewData["Title"] = "現場遊玩紀錄";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>🎮 現場遊玩紀錄</h3>
</div>

<!-- 快速新增 -->
<div class="row mb-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-play-circle"></i> 開始新遊玩
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">會員電話（選填）</label>
                            <div class="input-group">
                                <input type="text" id="phoneInput" class="form-control" placeholder="輸入電話號碼">
                                <button class="btn btn-outline-primary" type="button" onclick="searchMember()">
                                    <i class="bi bi-search"></i> 搜尋
                                </button>
                            </div>
                        </div>
                        <div id="memberInfo" class="alert alert-info mb-3" style="display: none;">
                            <strong id="memberName"></strong>（<span id="memberLevel"></span>）
                            <br>時單價：平日 <span id="weekdayRate"></span> 元/hr｜假日 <span id="holidayRate"></span> 元/hr
                            <input type="hidden" id="memberId">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">顧客姓名（非會員必填）</label>
                            <input type="text" id="customerName" class="form-control" placeholder="輸入姓名">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">電話（非會員必填）</label>
                            <input type="text" id="customerPhone" class="form-control" placeholder="輸入電話">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">開始時間</label>
                            <input type="datetime-local" id="startTime" class="form-control" value="@ViewBag.DefaultStartTime">
                        </div>
                        <button class="btn btn-success btn-lg w-100" onclick="startPlay()">
                            <i class="bi bi-play-fill"></i> 開始遊玩
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-info-circle"></i> 計費說明
            </div>
            <div class="card-body">
                <p><strong>會員</strong></p>
                <ul class="list-unstyled small mb-2">
                    <li>平日：$50/hr，上限 $180/日</li>
                    <li>假日：$60/hr，上限 $220/日</li>
                </ul>
                <p><strong>非會員</strong></p>
                <ul class="list-unstyled small mb-2">
                    <li>平日：$60/hr，上限 $240/日</li>
                    <li>假日：$70/hr，上限 $280/日</li>
                </ul>
                <hr>
                <p class="small text-muted mb-1"><i class="bi bi-alarm"></i> 計時方式：無條件進位（不滿1小時算1小時）</p>
                <p class="small text-muted mb-0"><i class="bi bi-cash-stack"></i> 金額 = min(時數 × 單價, 每日上限)</p>
            </div>
        </div>
    </div>
</div>

<!-- 進行中的遊玩名單 -->
<div class="row">
    <div class="col-md-12">
        @{
            var activePlays = ViewBag.ActivePlays as List<BordGameSpace.Models.PlayRecord>;
            var hasUnpaid = ViewBag.HasUnpaid as bool? ?? false;
        }

        <div class="card @(hasUnpaid ? "border-danger" : "border-info")">
            <div class="card-header @(hasUnpaid ? "bg-danger text-white" : "bg-info text-white")">
                @(hasUnpaid ? "⚠️ 待結帳顧客" : "🎮 進行中的遊玩") (@(activePlays?.Count ?? 0) 人)
            </div>
            <div class="card-body">
                @if (activePlays == null || !activePlays.Any())
                {
                    <p class="text-center text-muted">目前沒有進行中的遊玩</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>姓名</th>
                                    <th>電話</th>
                                    <th>會員等級</th>
                                    <th>開始時間</th>
                                    <th>已玩時數</th>
                                    <th>時單價</th>
                                    <th>金額</th>
                                    <th>狀態</th>
                                    <th>操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var play in activePlays)
                                {
                                    <tr class="@(play.Status == "Completed" ? "table-warning" : "")">
                                        <td>@play.MemberName</td>
                                        <td>@play.MemberPhone</td>
                                        <td>@(play.Member?.Level?.Name ?? "非會員")</td>
                                        <td>@play.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>
                                            @{
                                                var elapsed = (play.EndTime ?? (DateTime)ViewBag.TaiwanNow) - play.StartTime;
                                                var hours = Math.Floor(elapsed.TotalHours);
                                                var mins = elapsed.Minutes;
                                                <text>@hours 時 @mins 分</text>
                                            }
                                        </td>
                                        <td>$@play.HourlyRate</td>
                                        <td>$@((play.TotalHours ?? 0) * play.HourlyRate)</td>
                                        <td>
                                            @if (play.Status == "Playing")
                                            {
                                                <span class="badge bg-success">遊玩中</span>
                                            }
                                            else if (play.Status == "Completed")
                                            {
                                                <span class="badge bg-warning text-dark">待結帳</span>
                                            }
                                        </td>
                                        <td>
                                            @if (play.Status == "Playing")
                                            {
                                                <a asp-action="EndPlay" asp-route-id="@play.Id" class="btn btn-sm btn-outline-secondary">
                                                    <i class="bi bi-stop-fill"></i> 結束
                                                </a>
                                            }
                                            else if (play.Status == "Completed")
                                            {
                                                <a asp-controller="Pos" asp-action="CheckoutPlay" asp-route-playId="@play.Id" class="btn btn-sm btn-primary">
                                                    <i class="bi bi-cart"></i> 結帳
                                                </a>
                                            }
                                            <button class="btn btn-sm btn-outline-secondary" onclick="deletePlay(@play.Id)" @(play.Status == "CheckedOut" ? "disabled" : "")>
                                                <i class="bi bi-trash"></i> 刪除
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let memberData = null;

        // 搜尋會員
        async function searchMember() {
            const phone = document.getElementById('phoneInput').value.trim();
            if (!phone) {
                alert('請輸入電話號碼');
                return;
            }

            try {
                const response = await fetch('/PlayRecords/SearchMember', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'phone=' + encodeURIComponent(phone)
                });
                const data = await response.json();

                if (data.success) {
                    if (data.isMember) {
                        memberData = data.member;
                        document.getElementById('memberInfo').style.display = 'block';
                        document.getElementById('memberId').value = data.member.id;
                        document.getElementById('memberName').textContent = data.member.name;
                        document.getElementById('memberLevel').textContent = data.member.levelName;
                        document.getElementById('weekdayRate').textContent = data.member.weekdayHourlyRate;
                        document.getElementById('holidayRate').textContent = data.member.holidayHourlyRate;
                        document.getElementById('customerName').value = data.member.name;
                        document.getElementById('customerPhone').value = data.member.phone;
                    } else {
                        memberData = null;
                        document.getElementById('memberInfo').style.display = 'none';
                        document.getElementById('memberId').value = '';
                        document.getElementById('customerPhone').value = phone;
                    }
                }
            } catch (e) {
                alert('搜尋失敗');
            }
        }

        // 開始遊玩
        async function startPlay() {
            const startTime = document.getElementById('startTime').value;
            const customerName = document.getElementById('customerName').value.trim();
            const customerPhone = document.getElementById('customerPhone').value.trim();

            // 驗證
            if (!startTime) {
                alert('請選擇開始時間');
                return;
            }

            if (!memberData && !customerName) {
                alert('非會員請填桌號');
                return;
            }

            if (!memberData && !customerPhone) {
                alert('非會員請填人數或編號');
                return;
            }

            try {
                const response = await fetch('/PlayRecords/StartPlay', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        memberId: memberData?.id || null,
                        memberName: customerName || memberData?.name || '非會員',
                        phone: customerPhone || memberData?.phone || '',
                        startTime: new Date(startTime).toISOString()
                    })
                });
                const data = await response.json();

                if (data.success) {
                    alert(data.message);
                    window.location.reload();
                } else {
                    alert('錯誤: ' + data.message);
                }
            } catch (e) {
                alert('新增失敗: ' + e.message);
            }
        }

        // 刪除遊玩記錄
        async function deletePlay(id) {
            if (!confirm('確定要刪除這筆記錄嗎？')) return;

            try {
                const response = await fetch('/PlayRecords/Delete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'id=' + id
                });
                const data = await response.json();

                if (data.success) {
                    window.location.reload();
                } else {
                    alert('錯誤: ' + data.message);
                }
            } catch (e) {
                alert('刪除失敗');
            }
        }
    </script>
}
